<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="ygh-service"/>
    <property name="LOG_PATH" value="${YGH_LOG_PATH:-logs}"/>
    <property name="PATTERN" value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%-5level service=${appName} traceId=%X{traceId:-} requestId=%X{requestId:-} userId=%X{userId:-} logger=%logger{36} message=&quot;%replace(%msg){'[\r\n]+',' '}&quot;%n"/>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder><pattern>${PATTERN}</pattern><charset>UTF-8</charset></encoder>
    </appender>
    <appender name="ROLLING" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${appName}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archive/${appName}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>20MB</maxFileSize><maxHistory>14</maxHistory><totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder><pattern>${PATTERN}</pattern><charset>UTF-8</charset></encoder>
    </appender>
    <root level="${YGH_LOG_LEVEL:-INFO}"><appender-ref ref="CONSOLE"/><appender-ref ref="ROLLING"/></root>
</configuration>
